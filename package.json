{
  "name": "@mp-consulting/homebridge-unifi-protect",
  "version": "1.0.7",
  "displayName": "UniFi Protect",
  "description": "A Homebridge plugin that brings full HomeKit support to the UniFi Protect ecosystem, including HomeKit Secure Video, multi-controller setups, and high-performance streaming.",
  "author": {
    "name": "MP Consulting",
    "url": "https://github.com/mp-consulting"
  },
  "homepage": "https://github.com/mp-consulting/homebridge-unifi-protect#readme",
  "license": "(ISC AND MIT)",
  "repository": {
    "type": "git",
    "url": "git://github.com/mp-consulting/homebridge-unifi-protect.git"
  },
  "bugs": {
    "url": "http://github.com/mp-consulting/homebridge-unifi-protect/issues"
  },
  "type": "module",
  "engines": {
    "homebridge": ">=1.8.0 || >=2.0.0",
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0"
  },
  "keywords": [
    "homebridge",
    "homebridge-plugin",
    "homebridge-unifi-protect",
    "homekit",
    "homekit secure video",
    "hksv",
    "camera",
    "doorbell",
    "ffmpeg",
    "ubiquiti",
    "unifi",
    "unifi protect",
    "motion",
    "motion sensor",
    "mqtt",
    "protect",
    "security",
    "uck",
    "uck g2",
    "uck g2+",
    "uck gen2",
    "uck gen2+",
    "udm",
    "udm pro",
    "udm-pro",
    "unifi camera",
    "unifi cloud key",
    "unifi dream machine pro",
    "unifi ffmpeg",
    "unifi nvr",
    "unifi-nvr",
    "unifios",
    "ai pro",
    "g3 bullet",
    "g3 flex",
    "g3 instant",
    "g4 bullet",
    "g4 doorbell",
    "g4 flex",
    "g4 instant",
    "g4 pro",
    "g5 pro",
    "g6 instant",
    "rtsp"
  ],
  "scripts": {
    "prebuild": "npm run clean",
    "copy:ui-kit": "mkdir -p homebridge-ui/public/lib && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.css homebridge-ui/public/lib/ && cp node_modules/@mp-consulting/homebridge-ui-kit/dist/kit.js homebridge-ui/public/lib/",
    "build": "npm run copy:ui-kit && tsc",
    "clean": "shx rm -rf dist",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "watch": "npm run build && npm link && nodemon",
    "start": "npm run build && homebridge -U ./test/hbConfig -D -I -P .",
    "postpublish": "npm run clean",
    "prepublishOnly": "npm test && npm run lint && npm run build",
    "monitor:events": "npx tsx scripts/event-schema-monitor.ts"
  },
  "main": "dist/index.js",
  "dependencies": {
    "@homebridge/plugin-ui-utils": "2.2.3",
    "ffmpeg-for-homebridge": "2.2.2",
    "homebridge-plugin-utils": "1.33.0",
    "undici": "7.24.6",
    "unifi-protect": "4.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mp-consulting/homebridge-ui-kit": "^1.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "class-validator": "^0.15.1",
    "eslint": "^10.1.0",
    "homebridge": "^2.0.0-beta.55",
    "homebridge-config-ui-x": "^5.21.0",
    "nodemon": "^3.1.14",
    "shx": "0.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "@types/readable-stream": "4.0.23"
  }
}
